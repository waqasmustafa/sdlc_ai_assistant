<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════════════════════════
         Module Category — This creates the "AI Assistant" dropdown
         inside Settings → Users → Access Rights tab automatically.
         It appears alongside Sales, CRM, Inventory dropdowns etc.
         ══════════════════════════════════════════════════════════════ -->

    <record id="module_category_ai_assistant" model="ir.module.category">
        <field name="name">AI Assistant</field>
        <field name="description">Access levels for the AI Assistant module.</field>
        <field name="sequence">50</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Security Groups — These become the dropdown options:
           (empty) = No access → AI Assistant hidden
           User    = Can only chat
           Admin   = Chat + configure
         ══════════════════════════════════════════════════════════════ -->

    <record id="group_ai_user" model="res.groups">
        <field name="name">User: Chat Only</field>
        <field name="category_id" ref="module_category_ai_assistant"/>
        <field name="comment">Can use the AI assistant to chat and ask questions about Odoo data.</field>
    </record>

    <record id="group_ai_manager" model="res.groups">
        <field name="name">Admin: Chat &amp; Configure</field>
        <field name="category_id" ref="module_category_ai_assistant"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_user'))]"/>
        <field name="comment">Can chat and configure AI settings, models, and intents.</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         Record Rules — Users can only see their OWN conversations
         ══════════════════════════════════════════════════════════════ -->

    <record id="rule_conversation_user" model="ir.rule">
        <field name="name">AI Conversation: User sees own only</field>
        <field name="model_id" ref="model_ai_conversation"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ai_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Managers can see all conversations (audit) -->
    <record id="rule_conversation_manager" model="ir.rule">
        <field name="name">AI Conversation: Manager sees all</field>
        <field name="model_id" ref="model_ai_conversation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ai_manager'))]"/>
    </record>

    <record id="rule_message_user" model="ir.rule">
        <field name="name">AI Message: User sees own only</field>
        <field name="model_id" ref="model_ai_message"/>
        <field name="domain_force">[('conversation_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ai_user'))]"/>
    </record>

    <record id="rule_message_manager" model="ir.rule">
        <field name="name">AI Message: Manager sees all</field>
        <field name="model_id" ref="model_ai_message"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ai_manager'))]"/>
    </record>

</odoo>
